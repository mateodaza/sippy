{
  "name": "sippy",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@sippy/web",
    "dev:backend": "turbo run dev --filter=@sippy/backend",
    "dev:indexer": "turbo run dev --filter=@sippy/indexer",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "commitlint": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "overrides": {
      "jest-diff": "29.7.0",
      "pretty-format": "29.7.0"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "bufferutil",
      "esbuild",
      "keccak",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ],
    "patchedDependencies": {
      "@mysten/sui@1.45.2": "patches/@mysten__sui@1.45.2.patch",
      "porto@0.2.35": "patches/porto@0.2.35.patch"
    }
  }
}
